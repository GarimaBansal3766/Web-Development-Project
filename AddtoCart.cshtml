@{
    Layout = "UserLayout";
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

        // 🔄 Load cart items from DB
        function loadCart() {
            $.ajax({
                url: "/User/GetCartItems",   // ✅ CORRECT API FOR CART PAGE
                type: "GET",
                success: function (cart) {

                    // 🔐 Login redirect
                    if (cart.redirect) {
                        window.location.href = cart.redirect;
                        return;
                    }

                    var cartTableBody = $("#cartTableBody");
                    cartTableBody.empty();
                    var grandTotal = 0;

                    // 🛒 Empty cart
                    if (!cart || cart.length === 0) {
                        cartTableBody.append(`
                            <tr>
                                <td colspan="7" class="text-center">Cart is empty</td>
                            </tr>
                        `);
                        $("#grandTotal").text("₹0");
                        return;
                    }

                    // 🧾 Render cart rows
                    cart.forEach(function (item) {
                        cartTableBody.append(`
                            <tr>
                                <td>
                                    <img src="${item.image}"
                                         style="width:60px;height:60px;object-fit:contain;" />
                                </td>
                                <td>${item.name}</td>
                                <td>₹${item.price}</td>
                                <td>${item.size}</td>
                                <td>
                                    <input type="number"
                                           class="form-control quantityInput"
                                           data-cartid="${item.cartId}"
                                           value="${item.quantity}"
                                           min="1"
                                           style="width:80px;" />
                                </td>
                                <td>₹${item.totalAmount}</td>
                                <td>
                                    <button class="btn btn-danger btn-sm removeBtn"
                                            data-cartid="${item.cartId}">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        `);
                        grandTotal += item.totalAmount;
                    });

                    $("#grandTotal").text("₹" + grandTotal.toFixed(2));
                },
                error: function () {
                    alert("❌ Failed to load cart");
                }
            });
        }

        // ▶ Load cart on page load
        loadCart();

        // ❌ Remove item
        $(document).on("click", ".removeBtn", function () {
            var cartId = $(this).data("cartid");

            $.post("/User/RemoveFromCart", { cartId: cartId }, function (res) {
                if (res.redirect) {
                    window.location.href = res.redirect;
                    return;
                }
                loadCart();
            });
        });

        // 🔁 Update quantity
        $(document).on("input", ".quantityInput", function () {
            var cartId = $(this).data("cartid");
            var quantity = parseInt($(this).val());

            if (quantity < 1) {
                $(this).val(1);
                quantity = 1;
            }

            $.post("/User/UpdateCartQuantity", {
                cartId: cartId,
                quantity: quantity
            }, function (res) {
                if (res.redirect) {
                    window.location.href = res.redirect;
                    return;
                }
                loadCart();
            });
        });

        // 🧹 Clear cart
        $("#clearCartBtn").click(function () {
            if (!confirm("Are you sure you want to clear the cart?")) return;

            $.post("/User/ClearCart", function (res) {
                if (res.redirect) {
                    window.location.href = res.redirect;
                    return;
                }
                if (res.success) {
                    alert("🧹 Cart cleared successfully");
                    loadCart();
                }
            });
        });

        // 🛒 Place order
        $("#placeOrderBtn").click(function () {
            window.location.href = "/User/Order";
        });

    });
</script>

<div class="container mt-5">
    <h2 class="mb-4">🛒 Your Cart</h2>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Image</th>
                <th>Product</th>
                <th>Price</th>
                <th>Size</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="cartTableBody"></tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <h4>Grand Total: <span id="grandTotal">₹0</span></h4>
        <button id="clearCartBtn" class="btn btn-outline-danger">Clear Cart</button>
        <button id="placeOrderBtn" class="btn btn-success">Place Order</button>
    </div>
</div>
