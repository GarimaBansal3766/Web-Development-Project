<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online_Shoppng</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Online_Shoppng.styles.css" asp-append-version="true" />
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <header>
        <div style="background-color: paleturquoise; width: 100vw; margin: 0; padding: 0; overflow-x: hidden;">
            <div class="row mt-5">
                        <div id="textCarousel" class="carousel slide" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                <div class="carousel-item active">
                            <div class="row text-center">
                                <div class="col-md-12 d-flex justify-content-center align-items-center">🚀 Use Coupan code for extra 5 % discount BF1301 </div>
                                    </div>
                                </div>
                        <div class="carousel-item">
                                    <div class="row text-center ">
                                <div class="col-md-12 d-flex justify-content-center align-items-center">🎯 Latest Collection of lehriya is Out </div>
                                    </div>
                                </div>
                            </div>

                            <button class="carousel-control-prev" type="button" data-bs-target="#textCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" style="filter: invert(1);"></span>
                            </button>
                            <button class="carousel-control-next" type="button" data-bs-target="#textCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" style="filter: invert(1);"></span>
                            </button>
                        </div>
                    </div>
       
            <div class="row">

                <div class="col-md-4">
                </div>
                <div class="col-md-4 d-flex justify-content-center align-items-center">
                    <img src="~/images/logo.png" class="img-fluid w-15" style="margin-left:5px;" />

                  </div>
                <div class="col-md-4">
                </div>
            </div>
            <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
                <div class="container-fluid">
                    <div>
                        <a class="nav-link" href="/User/Profile">
                            <i class="bi bi-person-circle fs-4"></i>
                            <span class="ms-1">My Profile</span>
                        </a>

                    </div>
                    <div class="collapse navbar-collapse justify-content-center" id="navbarNav">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link active" href="/User/Home">Home</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" href="/User/Categories">Categories</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" href="/User/Products">Products</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" href="#">Help and support</a>
                            </li>
                        </ul>
                    </div>
                    <div class="d-flex align-items-center gap-3">
                        <a href="/User/AddtoCart" class="nav-link text-white">
                            <i class="bi bi-cart3 fs-4"></i>
                        </a>

                        <a href="javascript:void(0)" class="nav-link text-warning" id="logoutBtn">
                            <i class="bi bi-box-arrow-right fs-5"></i> Logout
                        </a>
                    </div>
                
                </div>
                
            </nav>

        </div>

        

    </header>
    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap and Bootstrap Icons (include these in your <head> if not already) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <footer class="bg-light py-4">
        <div class="container">
            <div class="row">
                <!-- Column 1: Logo, Contact Info, Social Icons -->
                <div class="col-md-6 d-flex">
                    <img src="~/images/logo.png" class="img-fluid me-3" style="max-width: 250px;" alt="Logo" />
                    <div class="d-flex flex-column justify-content-center">
                        <div><strong>Phone:</strong> +91 9358583766</div>
                        <div><strong>Mail:</strong> bansalfashions@gmail.com</div>
                        <div class="mt-2">
                            <strong>Follow Us</strong><br>
                            <a href="#" class="text-dark me-2 fs-5"><i class="bi bi-facebook"></i></a>
                            <a href="#" class="text-dark me-2 fs-5"><i class="bi bi-instagram"></i></a>
                            <a href="#" class="text-dark me-2 fs-5"><i class="bi bi-snapchat"></i></a>
                            <a href="#" class="text-dark fs-5"><i class="bi bi-youtube"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Column 2: Useful Links -->
                <div class="col-md-3 d-flex align-items-center justify-content-md-end mt-4 mt-md-0">
                    <div>
                        <h5 class="mb-3">Useful Links</h5>
                        <ul class="list-unstyled mb-0">
                            <li><a href="/Online/New_Product" class="text-dark text-decoration-none">Admin Panel</a></li>
                            <li><a href="#" class="text-dark text-decoration-none">About Us</a></li>
                            <li><a href="#" class="text-dark text-decoration-none">Size Chart</a></li>
                        </ul>
                    </div>
                </div>
                <div class="col-md-3 d-flex align-items-center justify-content-md-end mt-4 mt-md-0">
                    <div>
                        <h5 class="mb-3">Policies Links</h5>
                        <ul class="list-unstyled mb-0">
                            <li><a href="#" class="text-dark text-decoration-none">Privacy Policy</a></li>
                            <li><a href="#" class="text-dark text-decoration-none">Return Policy</a></li>
                            <li><a href="#" class="text-dark text-decoration-none">Terms Of Service</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<script>
    $(document).on("click", "#logoutBtn", function () {

        if (!confirm("Are you sure you want to logout?")) return;

        $.post("/Login/Logout", function () {
            window.location.href = "/User/Home";
        });
    });
</script>
