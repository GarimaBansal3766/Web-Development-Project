@{
    Layout = "UserLayout";
}
<style>
    .carousel-inner img {
        height: 600px; /* Set desired height */
        object-fit: cover; /* Ensures images cover the area */
    }
</style>

<div>
    <div id="fashionCarousel" class="carousel slide" data-bs-ride="carousel" data-bs-interval="2000">
        <div class="carousel-inner">
            <div class="carousel-item ">
                <img src="~/images/corousel 2.jpg" class="d-block w-100" alt="Elegant Dress">
            </div>
            <div class="carousel-item">
                <img src="~/images/corousel 1.jpg" class="d-block w-100" alt="Modern Outfit">
            </div>
            <div class="carousel-item active">
                <img src="~/images/corousel 3.jpg" class="d-block w-100" alt="Summer Collection">
            </div>
        </div>
    </div>
</div>
