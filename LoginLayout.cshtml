<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Online_Shoppng</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Online_Shoppng.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <div style="background-color: paleturquoise; width: 100vw; margin: 0; padding: 0; overflow-x: hidden;">
            <div class="row">
                @* style="background-color: paleturquoise; width: 100vw; margin: 0; padding: 0; overflow-x: hidden;"> *@
                <div class="col-md-4">
                </div>
                <div class="col-md-4" > 
                    <img src="~/images/logo.png" class="img-fluid w-15" style="margin-left:5px;" />
                </div>
                <div class="col-md-4">
    </div>
</div>
</div>
    </header>
    <div>
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
